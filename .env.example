# ─────────────────────────────────────────────────────────────
#  Atendente Psi. Deivid Oliveira — variáveis de ambiente
#  Copie para ".env" (local) ou configure no EasyPanel (deploy).
# ─────────────────────────────────────────────────────────────

PORT=3333

# ── Claude (o cérebro) ───────────────────────────────────────
# https://console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-5

# ── OpenRouter (só pra transcrever áudio — o "ouvido") ───────
# Opcional: sem isso, o bot responde pedindo texto quando chega áudio.
# https://openrouter.ai → Keys
OPENROUTER_API_KEY=
OPENROUTER_TRANSCRIBE_MODEL=google/gemini-2.5-flash

# ── Banco de dados (a fonte da verdade) ──────────────────────
# String de conexão do Postgres. No EasyPanel, use a URL interna do serviço Postgres.
# Ex.: postgres://usuario:senha@postgres:5432/atendente
DATABASE_URL=

# ── Evolution API (gateway do WhatsApp) ──────────────────────
EVOLUTION_URL=http://evolution-api:8080
EVOLUTION_INSTANCE=deivid
EVOLUTION_API_KEY=troque-esta-chave

# Segredo que a Evolution manda no header do webhook (configure igual nos dois lados)
WEBHOOK_TOKEN=troque-por-um-segredo-aleatorio

# ── Administração por conversa ───────────────────────────────
# SEU número pessoal (só ele vira admin). Só dígitos, com DDI. Ex.: 5534999030329
# IMPORTANTE: deve ser DIFERENTE do número do bot.
ADMIN_NUMBER=
# (Opcional) palavra-chave pra confirmar alterações sensíveis. Vazio = desligado.
ADMIN_PASSPHRASE=

# Minutos até o cliente receber o fallback caso você não responda uma dúvida escalada
ESCALATION_TIMEOUT_MIN=30

# (Opcional) para onde vão avisos de lead/escalação. Vazio = usa o ADMIN_NUMBER.
NOTIFY_NUMBER=

# Segundos de cache da base antes de reler do banco (invalidado a cada alteração)
CACHE_TTL=60
